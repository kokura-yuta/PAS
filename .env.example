ENVIRONMENT=development
DATABASE_URL=postgresql://user:password@localhost:5432/study_pas
OPENAI_API_KEY=your_openai_api_key
SESSION_SECRET_KEY=replace_with_at_least_32_random_characters
APP_BASE_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Tokyo
LOG_LEVEL=INFO
AI_DAILY_REQUEST_LIMIT=100

# 規約を重要改定した場合は値を変更すると、全ユーザーに再同意を求めます。
TERMS_VERSION=2026-07-20
PRIVACY_VERSION=2026-07-20
TERMS_EFFECTIVE_DATE=2026年7月20日

# 特定商取引法に基づく表示。すべて設定されるまで新規Premium決済は無効です。
LEGAL_BUSINESS_NAME=販売事業者名
LEGAL_REPRESENTATIVE=運営責任者名
LEGAL_ADDRESS=請求があった場合に遅滞なく開示します
LEGAL_PHONE=請求があった場合に遅滞なく開示します
LEGAL_EMAIL=support@example.com

# Stripe Premium（月額800円）。未設定時はPremium決済ボタンが無効になります。
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PREMIUM_PRICE_ID=price_replace_me

# パスワード再設定メール。本番では必須です。
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
